# Copy to .env.local and fill in real values. Never commit .env.local.

ANTHROPIC_API_KEY=
SCRAPINGBEE_API_KEY=
SERPAPI_KEY=

# Pinterest OAuth (developers.pinterest.com) — add PINTEREST_REDIRECT_URI
# as an allowed redirect URI in the app's dashboard settings.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/api/pinterest/callback
